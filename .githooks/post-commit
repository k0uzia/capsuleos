#!/bin/sh
# Push automatique vers le remote après chaque commit (sync vues inclus).
# Désactiver : CAPSULE_SKIP_AUTO_REMOTE_SYNC=1
# Installation : bash root/tools/install-git-hooks.sh
set -e

if [ "${CAPSULE_SKIP_AUTO_REMOTE_SYNC:-0}" = "1" ]; then
  exit 0
fi

depth="${CAPSULE_GIT_REMOTE_SYNC_DEPTH:-0}"
if [ "$depth" -ge 2 ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! git remote get-url origin >/dev/null 2>&1; then
  exit 0
fi

if ! git rev-parse --abbrev-ref "@{u}" >/dev/null 2>&1; then
  echo "post-commit CapsuleOS : pas d'upstream — push auto ignoré (git push -u origin <branche>)" >&2
  exit 0
fi

export CAPSULE_GIT_REMOTE_SYNC_DEPTH=$((depth + 1))
echo "post-commit CapsuleOS : synchronisation remote…"

if ! bash "$ROOT/usr/lib/capsuleos/tools/git-remote-sync.sh" push origin "$(git branch --show-current)"; then
  echo "post-commit CapsuleOS : push auto échoué — relancer : bash usr/lib/capsuleos/tools/git-remote-sync.sh push" >&2
fi

exit 0
