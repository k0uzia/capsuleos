#!/bin/sh
# Bloque le push si les vues générées (façades pick-os, embeds) ne sont pas à jour.
# Installation : bash root/tools/install-git-hooks.sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "pre-push CapsuleOS : synchronisation des vues…"
node usr/lib/capsuleos/tools/sync-all-views.mjs

if ! git diff --quiet --exit-code; then
    echo ""
    echo "✗ Push refusé : les vues générées diffèrent du dernier commit."
    echo "  Exécutez : node usr/lib/capsuleos/tools/sync-all-views.mjs"
    echo "  Puis committez les fichiers modifiés et relancez git push."
    echo ""
    git diff --stat
    exit 1
fi

echo "✓ Vues à jour — push autorisé."
