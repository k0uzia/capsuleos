# ── Cursor / IDE (rules + hooks versionnés sous root/.cursor/) ─────────────
root/.cursor/*
!root/.cursor/rules/
!root/.cursor/rules/**
!root/.cursor/hooks/
!root/.cursor/hooks/**
!root/.cursor/hooks.json

# ── Secrets & inventaire lab local (ne jamais committer) ───────────────────
etc/capsuleos/lab-inventory.json
etc/capsuleos/git-push-token
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.credentials.json

# ── Dépendances Node (lab uniquement — npm ci après clone) ─────────────────
node_modules/

# ── Staging proc / builds éphémères ───────────────────────────────────────
proc/*/staging/

# ── Instantanés resolve-agent (éphémères — root/docs/README.md §3) ────────
root/docs/inventaires/*-pipeline-resolve.json
root/docs/inventaires/*-formal-resolve.json
root/docs/inventaires/*-playbook-general-resolve.json

# ── Python lab ────────────────────────────────────────────────────────────
root/tools/lab/__pycache__/
*.py[cod]
__pycache__/

# ── Playwright / smokes locaux ────────────────────────────────────────────
playwright-report/
test-results/
blob-report/
.playwright/
playwright/.cache/

