# CapsuleOS — durcissement Apache (mutualisé)
# Cible : https://os.lacapsule.org · aligné OWASP Top 10 (2021) — voir commentaires par section
# Prérequis : mod_headers, mod_rewrite, mod_setenvif · HTTPS actif côté hébergeur

# ── A05 — Configuration sécurisée ───────────────────────────────────────────
# Pas de listing de répertoires ni d’options dangereuses (remplace « Options All »).
Options -Indexes -MultiViews +FollowSymLinks
ServerSignature Off

# ── A02 — Échecs cryptographiques : redirection HTTPS ───────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]
</IfModule>

# ── A01 — Contrôle d’accès : chemins et méthodes ────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Fichiers cachés (.git, .env, .htaccess lu par Apache mais pas listé)
    RewriteRule (^|/)\.(?!well-known/) - [F,L]

    # Arborescences dev / sensibles (ne doivent pas être web-accessibles)
    RewriteRule ^(?:node_modules|\.cursor|\.git)(?:/|$) - [F,L]
    RewriteRule ^etc/capsuleos/lab-inventory\.json$ - [F,L]
    RewriteRule ^root/tools/(?:lab|install-git-hooks\.sh) - [F,L]

    # Méthodes HTTP : site statique — GET, HEAD, OPTIONS uniquement
    RewriteCond %{REQUEST_METHOD} !^(GET|HEAD|OPTIONS)$ [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# ── A05 / A08 — En-têtes de sécurité ───────────────────────────────────────
<IfModule mod_headers.c>
    # A02 — HSTS (HTTPS obligatoire ci-dessus)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # A03 / A05 — MIME sniffing, clickjacking, fuite referrer
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"

    # A05 — Surface API navigateur (CapsuleOS n’utilise pas ces périphériques)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

    # A08 — CSP pragmatique : CapsuleOS = HTML/CSS/JS statiques + inline (pas de nonces déployés)
    # Ajuster frame-src / frame-ancestors si d’autres domaines embarquent l’OS en iframe.
    Header always set Content-Security-Policy "\
default-src 'self'; \
base-uri 'self'; \
object-src 'none'; \
form-action 'self'; \
script-src 'self' 'unsafe-inline'; \
style-src 'self' 'unsafe-inline'; \
img-src 'self' data: blob:; \
font-src 'self' data:; \
connect-src 'self'; \
media-src 'self' blob:; \
worker-src 'self'; \
frame-src 'self' https://lacapsule.org https://www.lacapsule.org; \
frame-ancestors 'self' https://lacapsule.org https://www.lacapsule.org; \
upgrade-insecure-requests"

    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # A01 — CORS : origine exacte (pas de « /* » dans Allow-Origin — invalide)
    # Uniquement si un autre site lacapsule.org charge des ressources en fetch cross-origin.
    SetEnvIf Origin "^https://(www\.)?lacapsule\.org$" CORS_ORIGIN=$0
    SetEnvIf Origin "^https://os\.lacapsule\.org$" CORS_ORIGIN=$0
    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, HEAD, OPTIONS" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Headers "Content-Type" env=CORS_ORIGIN
    Header always set Vary "Origin" env=CORS_ORIGIN
</IfModule>

# ── A05 — Types sensibles : pas d’exécution côté serveur ───────────────────
<FilesMatch "\.(?:env|ini|log|sh|md|mdc|jsonl|lock|gitignore|gitattributes)$">
    Require all denied
</FilesMatch>

# Autoriser les JSON servis au runtime CapsuleOS (manifestes, catalogues)
<FilesMatch "\.(?:json|js|css|html|webp|png|svg|woff2?|ttf|ico|wasm)$">
    Require all granted
</FilesMatch>

# ── A05 — Cache public pour assets versionnés (perf + intégrité CDN optionnelle)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresDefault "access plus 1 hour"
</IfModule>
