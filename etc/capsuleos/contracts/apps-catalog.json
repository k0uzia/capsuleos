        "system_monitor": { "chromeProvider": "libadwaita-gnome", "template": "system_monitor.html", "skinCss": "system_monitor.skin.css", "functionalDepth": "partial" },
        "tour": { "chromeProvider": "libadwaita-gnome", "template": "tour.html", "skinCss": "tour.skin.css", "functionalDepth": "partial" },
        "characters": { "chromeProvider": "libadwaita-gnome", "template": "characters.html", "skinCss": "characters.skin.css", "functionalDepth": "partial" }
