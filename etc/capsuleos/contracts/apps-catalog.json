{
  "version": 1,
  "description": "Contrat catalogue applications VM → CapsuleOS — vendor-agnostique, overrides par registryId.",
  "statutCodes": ["ok", "partiel", "absent", "decorative", "capsuleOnly", "notOnVm"],
  "priorites": ["P0", "P1", "P2", "P3"],
  "predicates": {
    "AppV": "Inventaire VM apps collecté (*-vm-apps-installed.json)",
    "AppC": "Catalogue strict généré et smoke-apps-catalog OK",
    "AppP0": "Toutes les apps P0 onVm exigeant un slot sont ok",
    "AppL": "Lab apps — run-apps-lab.mjs",
    "AppΣ": "AppV ∧ AppC ∧ AppP0 ∧ AppL"
  },
  "toolkits": {
    "gnome": {
      "collectPattern": "org.gnome.*.desktop",
