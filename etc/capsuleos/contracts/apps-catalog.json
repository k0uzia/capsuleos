        "screenshot": { "chromeProvider": "libadwaita-gnome", "template": "screenshot.html", "skinCss": "screenshot.skin.css", "functionalDepth": "partial" },
        "librewriter": { "chromeProvider": "libadwaita-gnome", "template": "librewriter.html", "skinCss": "librewriter.skin.css", "functionalDepth": "partial" },
