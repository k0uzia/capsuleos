{
  "version": 1,
  "description": "Couches pipeline CapsuleOS — ordre séquentiel (§5.2 plan maître reproduction OS)",
  "coherenceContract": "etc/capsuleos/contracts/os-reproduction-coherence.json",
  "storeChain": "etc/capsuleos/contracts/store-replication-chain.json",
  "entrypoint": "usr/lib/capsuleos/tools/lab/run-capsule-pipeline.mjs",
  "resolver": "usr/lib/capsuleos/tools/lab/resolve-agent-action.mjs --scope pipeline",
  "layers": [
    {
      "id": "socle",
      "label": "Socle dépôt",
      "predicates": ["H2"]
    },
    {
      "id": "ground-truth",
      "label": "Vérité machine manifeste",
      "predicates": ["ManΣ"]
    },
    {
      "id": "apps",
      "label": "Catalogue applications",
      "predicates": ["AppΣ"]
    },
    {
      "id": "store",
      "label": "Magasin GNOME Software",
      "predicates": ["StoreG", "StoreΣ", "StoreVp"],
      "chain": "etc/capsuleos/contracts/store-replication-chain.json"
    },
    {
      "id": "playbook",
      "label": "Playbook général",
      "predicates": ["PbΣ"]
    },
    {
      "id": "settings-effects",
      "label": "Effets système Paramètres (couche Se)",
      "predicates": ["Se", "SeΣ"],
      "chain": "etc/capsuleos/contracts/settings-effects-chain.json",
      "note": "Paramètres → bus capsule:* → shell/apps ; distinct de Vp"
    },
    {
      "id": "visual",
      "label": "Parité visuelle shell",
      "predicates": ["Vp"]
    },
    {
      "id": "release",
      "label": "Clôture release",
      "predicates": ["H6"]
    },
    {
      "id": "apps-parity",
      "label": "Parité visuelle applications P0",
      "predicates": ["AppVp"],
      "chain": "etc/capsuleos/contracts/apps-replication-chain.json",
      "note": "Après H6 — AppVv → AppVc → AppVp (R-APP-VV/VC/VP)"
    },
    {
      "id": "fidelity",
      "label": "Fidélité visuelle transversale",
      "predicates": ["Tf"]
    }
  ]
}
