{
  "version": 1,
  "description": "Scénarios utilisateur pédagogiques GNOME Firefox (firefox.desktop) — slot CapsuleOS `firefox`, gabarit `firefox.html`. Toolkit gnome (Rocky, Fedora, Alma, Ubuntu).",
  "doc": "root/docs/inventaires/linux-alma-firefox-vm-inventory.json",
  "slot": "firefox",
  "template": "firefox.html",
  "kernel": "usr/lib/capsuleos/shells/linux/firefoxBrowser.js",
  "registryIds": ["linux-alma", "linux-rocky", "linux-fedora", "linux-ubuntu"],
  "predicates": {
    "FΣ": "Contrat valide + kernel syncFirefoxGnomeDataset + gabarit data-firefox-gnome-* + simulatedWebResolver",
    "F1": "F1 ouvrir Firefox → page d'accueil / nouvel onglet",
    "F2": "F2 saisir alias ou URL → page web locale (La Capsule)",
    "F3": "F3 nouvel onglet + bascule entre onglets",
    "F4": "F4 favori barre signets (chrome Proton GNOME)",
    "F5": "F5 recherche → SERP locale ou host connu (linuxmint.com)",
    "F6": "F6 raccourcis nouvel onglet VM (Amazon, Temu, Wikipédia, YouTube, Reddit)",
    "F7": "F7 historique retour/avant après navigations enchaînées",
    "F8": "F8 SERP → clic résultat → retour kernel (pont iframe)"
