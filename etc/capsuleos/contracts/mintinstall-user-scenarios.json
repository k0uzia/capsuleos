{
  "version": 1,
  "description": "Scénarios utilisateur pédagogiques Logithèque (mintinstall) — toolkit Cinnamon linux-mint.",
  "doc": "root/docs/inventaires/linux-mint-mintinstall-vm.json",
  "slot": "mintinstall",
  "template": "mintinstall.html",
  "kernel": "usr/lib/capsuleos/shells/linux/mintinstall.js",
  "storeKernel": "usr/lib/capsuleos/shells/linux/mint-store-catalog.js",
  "registryIds": ["linux-mint"],
  "predicates": {
    "ScΣ": "Contrat valide + kernel implémente handlers data-mi-*",
    "Sc1": "Mi1 install simulé LibreOffice Writer → Ouvrir",
    "Sc2": "Mi2 recherche → fiche → install",
    "Sc3": "Mi3 mises à jour (update_manager lié)",
    "Sc4": "Mi4 onglet Installés → lancer application",
    "Sc5": "Mi5 store file_roller → Installés",
    "Sc6": "Mi6 store LibreOffice → librewriter",
    "Sc7": "Mi7 store Agenda → calendar",
    "Sc8": "Mi8 thunderbird → thunderbird",
    "Sc9": "Mi9 transmission → Installés",
    "Sc10": "Mi10 warpinator → warpinator",
    "Sc11": "Mi11 rhythmbox → rhythmbox",
    "Sc12": "Mi12 simple_scan → simple_scan"
  },
  "scenarios": [
    {
      "id": "Mi1",
      "priority": "P0",
      "title": "Découvrir et installer une application",
      "locale": "fr-FR",
      "vmGroundTruth": {
        "appId": "librewriter",
        "apt": "libreoffice-writer",
        "onVm": true,
        "buttonFlow": ["Installer", "Installation…", "Ouvrir"]
      },
      "steps": [
        { "id": "open-mintinstall", "action": "openWindowByDataLink", "target": "mintinstall", "label": "Ouvrir Logithèque" },
        { "id": "nav-office", "selector": "[data-mi-cat=\"office\"]", "label": "Catégorie Bureautique" },
        { "id": "detail-writer", "selector": "[data-mi-pkg=\"librewriter\"]", "label": "Sélectionner LibreOffice Writer" },
        { "id": "detail-install", "selector": "[data-mi-detail-install]", "expectTextBefore": "Installer", "label": "Cliquer Installer" },
        { "id": "install-progress", "predicate": "dataset.miInstalling", "label": "Progression simulée" },
        { "id": "install-open", "selector": "[data-mi-open=\"librewriter\"]", "expectTextAfter": "Ouvrir", "label": "Bouton Ouvrir disponible" },
        { "id": "launch-app", "selector": "[data-mi-open=\"librewriter\"]", "expectWindow": "librewriter", "label": "Ouvrir l'application installée" }
      ],
      "proofs": {
        "smoke": "smoke-mint-store-scenarios.mjs --scenario Mi1",
        "capture": "mint-capsule-mintinstall-install-open.png"
      }
    },
    {
      "id": "Mi2",
      "priority": "P0",
      "title": "Rechercher et installer",
      "locale": "fr-FR",
      "steps": [
        { "id": "open-mintinstall", "action": "openWindowByDataLink", "target": "mintinstall", "label": "Ouvrir Logithèque" },
        { "id": "search", "selector": "#mi-search", "value": "writer", "label": "Rechercher writer" },
        { "id": "search-result", "selector": "#mi-search-list [data-mi-pkg=\"librewriter\"]", "label": "Ouvrir fiche depuis résultats" },
        { "id": "install", "selector": "[data-mi-detail-install]", "label": "Installer depuis fiche recherche" }
      ],
      "proofs": {
        "smoke": "smoke-mint-store-scenarios.mjs --scenario Mi2",
        "capture": "mint-capsule-mintinstall-search-install.png"
      }
    },
    {
      "id": "Mi3",
      "priority": "P0",
      "title": "Appliquer toutes les mises à jour",
      "locale": "fr-FR",
      "vmNote": "mintupdate — scénario pédagogique via Gestionnaire de mise à jour",
      "steps": [
        { "id": "open-mintinstall", "action": "openWindowByDataLink", "target": "mintinstall", "label": "Ouvrir Logithèque" },
        { "id": "open-updates", "action": "openWindowByDataLink", "target": "update_manager", "label": "Ouvrir Gestionnaire de mise à jour" },
        { "id": "refresh-updates", "selector": "[data-um-action=\"refresh\"]", "label": "Actualiser les mises à jour" },
        { "id": "select-all", "selector": "[data-um-action=\"selectAll\"]", "label": "Tout sélectionner" },
        { "id": "update-all", "selector": "[data-um-action=\"install\"]", "label": "Installer les mises à jour" },
        { "id": "empty-state", "selector": "#um-empty:not([hidden])", "label": "État système à jour" }
      ],
      "proofs": {
        "smoke": "smoke-mint-store-scenarios.mjs --scenario Mi3",
        "capture": "mint-capsule-mintinstall-updates-empty.png"
      }
    },
    {
      "id": "Mi4",
      "priority": "P0",
      "title": "Lancer depuis Installés",
      "locale": "fr-FR",
