{
  "htaccessPath": ".htaccess",
  "requiredOptions": ["-Indexes", "ServerSignature Off"],
  "requiredRewritePatterns": [
    "RewriteCond %{HTTPS} !=on",
    "node_modules",
    "REQUEST_METHOD} !\\^\\(GET\\|HEAD\\|OPTIONS\\)"
  ],
  "requiredHeaders": [
    "Strict-Transport-Security",
    "X-Content-Type-Options",
    "X-Frame-Options",
    "Content-Security-Policy",
    "Referrer-Policy",
    "Cross-Origin-Opener-Policy",
    "Cross-Origin-Resource-Policy",
    "Permissions-Policy"
  ],
  "requiredFilesMatchDeny": [
    "\\.(?:env|ini|log|sh|md|mdc|jsonl|lock|gitignore|gitattributes)$"
  ]
}
