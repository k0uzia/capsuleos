{
  "version": 1,
  "description": "Playbook général multiplateforme — orchestre playbooks universels, toolkit et bout de chaîne (τ) par registryId.",
  "validated": true,
  "validatedAt": "2026-06-06",
  "validatedNote": "Structure + smoke + Rocky référence ; mode auto activable via autoExecution.",
  "doc": "root/docs/procedure-playbook-general.md",
  "predicates": {
    "Pb": "Playbook général défini (ce contrat + procédure)",
    "PbU": "Couche universelle terminée (H2, M, I, A, T)",
    "PbT": "Playbook toolkit terminé pour le toolkit du registre",
    "Pbτ": "Playbook bout de chaîne documenté (spécificités environnement)",
    "PbΣ": "PbU ∧ PbT ∧ Pbτ — prêt pour patch skin ciblé (H5) ou clôture H6"
  },
  "autoExecution": {
    "enabled": true,
    "rule": "R-AUTO",
    "requiresValidation": true,
    "orchestrator": "usr/lib/capsuleos/tools/lab/run-playbook-general.mjs",
    "maxStepsPerInvocation": 16,
    "note": "Actif après validation du contrat ; exécute la prochaine étape admissible sans confirmation humaine."
  },
  "layers": {
    "universal": {
      "label": "Playbooks universels (tous vendors / branches / versions)",
      "predicates": ["H2", "M", "I", "A", "T"],
      "steps": [
        {
          "id": "u-validate-all",
          "negates": ["H2"],
          "script": "usr/lib/capsuleos/tools/validate-all.mjs",
          "args": []
        },
        {
          "id": "u-registry-brief",
          "requires": ["H2"],
          "optional": true,
          "script": "usr/lib/capsuleos/tools/print-agent-brief.mjs",
          "args": ["{id}"]
        },
        {
          "id": "u-vm-inventory",
          "negates": ["I"],
          "requires": ["M"],
          "note": "Collecter inventaires/<id>-vm.json si absent — voir procedure-clonage-os-depuis-vm.md",
          "manualGate": true
        },
        {
          "id": "u-manifest-chain",
          "negates": ["ManΣ"],
          "requires": ["M"],
          "script": "usr/lib/capsuleos/tools/lab/run-manifest-replication-chain.mjs",
          "args": ["--id", "{id}", "--auto", "--write"],
          "note": "Manifeste distribution VM → playbook → staging → import (tous vendors/toolkits)"
        },
        {
          "id": "u-verify-assets",
          "negates": ["A"],
          "requires": ["I"],
          "script": "usr/lib/capsuleos/tools/lab/verify-playbook-assets.mjs",
          "args": ["--registry", "{id}", "--strict"],
          "toolkits": ["gnome"]
        },
        {
          "id": "u-collect-assets",
          "negates": ["S"],
          "requires": ["M", "A"],
          "script": "usr/lib/capsuleos/tools/lab/collect-vm-gnome-settings-assets.mjs",
          "args": ["--id", "{id}"],
          "toolkits": ["gnome"]
        }
      ]
    },
    "toolkit": {
      "label": "Playbooks spécifiques toolkit (réutilisables par vendor)",
      "predicates": ["PbT"],
      "map": {
        "gnome": {
          "domain": "gnome-settings-playbook",
          "doc": "root/docs/procedure-creation-playbook-gnome-settings.md",
          "orchestrator": "usr/lib/capsuleos/tools/lab/run-replication-chain.mjs",
          "completeWhen": ["V", "G", "Vc", "Vp"],
          "description": "Paramètres GNOME : tour panneaux, interactions, enquête visuelle, gsettings, parité Capsule"
        },
        "kde": {
          "domain": "kde-ground-truth",
          "doc": "root/docs/ground-truth-kde.md",
          "contract": "etc/capsuleos/contracts/kde-ground-truth-chain.json",
          "orchestrator": "usr/lib/capsuleos/tools/lab/map-kde-ground-truth-gaps.mjs",
          "completeWhen": ["KdΠ", "KdP4"],
          "description": "Ground truth Plasma — pivot linux-kde-neon, panel/kickoff/tray/Dolphin/Discover, propagation P4"
        },
        "cinnamon": {
          "status": "stub",
          "doc": "root/docs/procedure-playbook-general.md#toolkit-cinnamon",
          "description": "À brancher — Nemo/Cinnamon control center"
        },
        "cosmic": {
          "status": "stub",
          "description": "À brancher — COSMIC settings"
        }
      }
    },
    "tail": {
      "label": "Playbook bout de chaîne τ — spécificités environnement",
      "predicates": ["Pbτ"],
      "requires": ["PbT"],
      "steps": [
        {
          "id": "tau-collect",
          "negates": ["Pbτ"],
          "script": "usr/lib/capsuleos/tools/lab/collect-playbook-tail.mjs",
          "args": ["--id", "{id}"]
        },
        {
          "id": "tau-review",
          "requires": ["Pbτ"],
          "optional": true,
          "note": "Revue humaine ou agent : écarts P0/P1, doc officielle, interactions VM"
        }
      ],
      "outputs": {
        "inventory": "root/docs/inventaires/{id}-playbook-tail.json",
        "markdown": "root/docs/inventaires/{id}-playbook-tail.md"
      }
    }
  },
  "rules": [
    "R-PB1  ¬PbU  →  couche universal avant toolkit",
    "R-PB2  PbU ∧ ¬PbT  →  orchestrateur toolkit (run-replication-chain --auto)",
    "R-PB3  PbT ∧ ¬Pbτ  →  collect-playbook-tail (doc officielle + VM lab)",
    "R-PB4  PbΣ  →  H5 patch minimal skin OU extension P1 ; puis H6",
    "R-PB-AUTO  validated ∧ ∃! step  →  run-playbook-general --auto"
  ]
}
