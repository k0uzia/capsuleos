{
  "version": 1,
  "status": "active",
  "description": "Catalogue apps installables via le magasin natif de chaque OS — extension pédagogique au-delà du ground truth VM (defaultInstalled: false).",
  "slotsManifestRef": "etc/capsuleos/contracts/slots-manifest.json",
  "presentationBindingsRef": "etc/capsuleos/contracts/presentation-bindings.json",
  "principles": [
    "VM prime : seules les apps onVm=true restent dans le shell par défaut",
    "storeInstallable=true : l'utilisateur peut simuler une installation depuis le magasin OS",
    "postInstall : slot Capsule déjà abouti (Mint v3 ou GNOME ScΣ) — pas de nouveau gabarit",
    "Sources documentées par registryId — jamais inventer un paquet absent des dépôts officiels"
  ],
  "sessionStoragePattern": {
    "namespace": "capsule-store-installed",
    "keyTemplate": "capsule-store-installed:{registryId}",
    "valueShape": {
      "appIds": [
        "string — desktopId ou flatpak app id"
      ],
      "installedAt": "ISO8601",
      "source": "rpm | apt | flatpak | snap"
    },
    "referenceScenario": "software-user-scenarios.json — cycle C15 (GNOME Software) · extension S1+ prévue"
  },
  "registryOverridesExtension": {
    "note": "Champs optionnels à ajouter dans apps-catalog.json registryOverrides.<id>.apps.<desktopId>",
    "fields": {
      "storeInstallable": "boolean — proposé au magasin simulé si slot Capsule ok/partiel",
      "defaultInstalled": "boolean — false = extension magasin ; true ou absent = ground truth VM"
    }
  },
  "storeFrontByRegistry": {
    "linux-mint": {
      "slot": "mintinstall",
      "labelFr": "Logithèque",
      "sources": [
        "apt",
        "flatpak"
      ],
      "doc": "https://mintguide.miraheze.org/wiki/Software_Manager"
    },
    "linux-rocky": {
      "slot": "update_manager",
      "appId": "org.gnome.Software",
      "labelFr": "Logiciels",
      "sources": [
        "rpm",
        "flatpak"
      ],
      "doc": "https://docs.redhat.com/en/documentation/red_hat_enterprise_linux/10/html/administering_rhel_by_using_the_gnome_desktop_environment/installing-applications-by-using-flatpak"
    },
    "linux-alma": {
      "slot": "update_manager",
      "appId": "org.gnome.Software",
      "labelFr": "Logiciels",
      "sources": [
        "rpm",
        "flatpak"
      ],
      "doc": "https://flathub.org/en/setup/AlmaLinux"
    },
    "linux-fedora": {
      "slot": "update_manager",
      "appId": "org.gnome.Software",
      "labelFr": "Logiciels",
      "sources": [
        "rpm",
        "flatpak"
      ],
      "doc": "https://docs.fedoraproject.org/en-US/fedora/latest/system-administrators-guide/package-management/DNF/"
    },
    "linux-ubuntu": {
      "slot": "update_manager",
      "appId": "snap-store",
      "labelFr": "Centre d'applications",
      "sources": [
        "snap",
        "deb",
        "flatpak"
      ],
      "flatpakNote": "Flatpak via gnome-software + plugin — absent App Center par défaut",
      "doc": "https://ubuntu.fan/en/docs/desktop-use/basics/software-install"
    },
    "linux-popos": {
      "slot": "update_manager",
