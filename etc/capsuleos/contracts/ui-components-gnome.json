{
  "version": 1,
  "toolkit": "gnome",
  "scope": "default-apps",
  "description": "Catalogue composants UI GNOME (libadwaita/GTK4) — apps par défaut du toolkit. Source normative : HIG + Components GNOME. Projection CapsuleOS : gabarits usr/share + tokens CSS.",
  "status": "model",
  "extendsLater": ["cinnamon", "kde", "cosmic"],
  "sources": {
    "higRoot": "https://developer.gnome.org/hig/",
    "higResources": "https://developer.gnome.org/hig/resources.html",
    "gnomeComponents": "https://developer.gnome.org/components/",
    "libadwaitaCssVars": "https://gnome.pages.gitlab.gnome.org/libadwaita/doc/1-latest/css-variables.html",
    "libadwaitaStyleClasses": "https://gnome.pages.gitlab.gnome.org/libadwaita/doc/1-latest/style-classes.html",
    "appsGnome": "https://apps.gnome.org/fr/",
    "capsuleHigInventory": "root/docs/inventaires/gnome-hig-resources.json",
    "capsuleDoc": "root/docs/convention-composants-gnome.md"
  },
  "levels": {
    "N0": {
      "label": "Primitives design (tokens)",
      "paths": [
        "usr/share/capsuleos/themes/clusters/toolkit-gnome/variables.css",
        "usr/share/capsuleos/themes/linux/gnome-app-csd.base.css",
        "usr/share/capsuleos/themes/linux/window-chrome.gnome.base.css",
        "usr/share/capsuleos/themes/linux/gnome-shell-preferences.base.css"
      ]
    },
    "N1": {
      "label": "Composants plateforme documentés",
      "contractKey": "components"
    },
    "N2": {
      "label": "Compositions applicatives (slots catalogue)",
      "contractKey": "appCompositions"
    }
  },
  "components": {
    "gnome.adw-application-window": {
      "labelFr": "Fenêtre application (CSD)",
      "gnomeWidget": "AdwApplicationWindow",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/windows.html",
      "capsuleCss": ["usr/share/capsuleos/themes/linux/gnome-app-csd.base.css"],
      "capsuleSelectors": [".gnome-app--csd", ".windowElement[data-window-chrome-toolkit=\"gnome\"]"],
      "cssTokens": ["--gnome-adw-headerbar-h", "--gnome-adw-headerbar-pad-x", "--gnome-adw-headerbar-gap"],
      "states": ["default", "maximized", "fullscreen"],
      "acquisitionVm": ["capture fenêtre entière CSD", "mesurer hauteur headerbar", "vérifier masquage rail Capsule #windowHeader"]
    },
    "gnome.adw-header-bar": {
      "labelFr": "Barre d'en-tête",
      "gnomeWidget": "AdwHeaderBar",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/header-bars.html",
      "capsuleCss": ["usr/share/capsuleos/themes/linux/gnome-app-csd.base.css"],
      "capsuleSelectors": [".gnome-calc__header", ".gnome-settings__headerbar", ".gnome-software__headerbar", ".gnome-shot__headerbar"],
      "cssTokens": ["--gnome-adw-headerbar-h", "--gnome-adw-headerbar-gap"],
      "states": ["default", "backdrop"],
      "acquisitionVm": ["boutons start/center/end", "titre centré ou vide", "icônes symboliques 16px"]
    },
    "gnome.adw-navigation-split": {
      "labelFr": "Navigation split (sidebar + contenu)",
      "gnomeWidget": "AdwNavigationSplitView",
      "higUrl": "https://developer.gnome.org/hig/patterns/nav/sidebars.html",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/nemo.base.css"],
      "capsuleSelectors": [".nautilus-app", ".nemo-app"],
      "states": ["sidebar-visible", "sidebar-collapsed", "narrow"],
      "acquisitionVm": ["largeur sidebar", "bouton replier", "fil d'Ariane"]
    },
    "gnome.gtk-column-view": {
      "labelFr": "Vue colonnes (fichiers)",
      "gnomeWidget": "GtkColumnView",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/list-column-views.html",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/nemo.base.css"],
      "states": ["selection-single", "selection-multiple", "sort-column"],
      "acquisitionVm": ["en-têtes colonnes", "ligne sélectionnée", "zone liste vide"]
    },
    "gnome.gtk-search-entry": {
      "labelFr": "Champ de recherche",
      "gnomeWidget": "GtkSearchEntry",
      "higUrl": "https://developer.gnome.org/hig/patterns/nav/search.html",
      "capsuleSelectors": [".gnome-search-entry", "[data-gnome-search]"],
      "states": ["empty", "focused", "with-results"],
      "acquisitionVm": ["placeholder FR", "icône loupe", "effacement"]
    },
    "gnome.adw-preferences-page": {
      "labelFr": "Page Paramètres",
      "gnomeWidget": "AdwPreferencesPage",
      "higUrl": "https://developer.gnome.org/hig/patterns/nav/settings.html",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/themes_gnome.base.css", "usr/share/capsuleos/themes/linux/gnome-shell-preferences.base.css"],
      "capsuleSelectors": [".gnome-settings__page", ".gnome-settings__sidebar"],
      "states": ["sidebar-nav", "content-scroll"],
      "acquisitionVm": ["liste panneaux gauche", "titre panneau actif", "groupe boxed-list"]
    },
    "gnome.adw-preferences-group": {
      "labelFr": "Groupe préférences (boxed list)",
      "gnomeWidget": "AdwPreferencesGroup",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/boxed-lists.html",
      "capsuleCss": ["usr/share/capsuleos/themes/linux/gnome-shell-preferences.base.css"],
      "capsuleSelectors": [".gnome-settings__group", ".gnome-settings__row"],
      "states": ["default", "interactive-row", "switch-row", "combo-row"],
      "acquisitionVm": ["séparateurs", "sous-titre row", "switch on/off"]
    },
    "gnome.gtk-grid-view": {
      "labelFr": "Grille / pavé",
      "gnomeWidget": "GtkGrid",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/grid-views.html",
      "capsuleSelectors": [".gnome-calc__keypad", ".math-buttons"],
      "states": ["default", "pressed-key"],
      "acquisitionVm": ["espacement cellules", "coins arrondis boutons", "couleur opérateurs"]
    },
    "gnome.popover": {
      "labelFr": "Popover",
      "gnomeWidget": "GtkPopover",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/popovers.html",
      "capsuleSelectors": [".gnome-calc__mode-popover", "[role=\"dialog\"][data-gnome-popover]"],
      "states": ["open", "closed"],
      "acquisitionVm": ["ancrage bouton", "ombre portée", "liste options"]
    },
    "gnome.adw-toolbar-view": {
      "labelFr": "Vue avec barre d'outils",
      "gnomeWidget": "AdwToolbarView",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/header-bars.html",
      "capsuleSelectors": [".viewer-app__toolbar", ".gnome-baobab__header"],
      "states": ["default"],
      "acquisitionVm": ["barre sous header ou intégrée", "actions primaires"]
    },
    "gnome.placeholder-page": {
      "labelFr": "Page vide / placeholder",
      "gnomeWidget": "AdwStatusPage",
      "higUrl": "https://developer.gnome.org/hig/patterns/feedback/placeholders.html",
      "states": ["empty-state"],
      "acquisitionVm": ["illustration", "titre", "bouton action"]
    },
    "gnome.browser-chrome": {
      "labelFr": "Chrome navigateur (Firefox)",
      "higUrl": "https://developer.gnome.org/hig/patterns/nav/tabs.html",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/firefox.base.css"],
      "chromeProvider": "firefox-gnome",
      "states": ["tab-bar", "url-bar", "private-browsing"],
      "acquisitionVm": ["onglets", "barre URL", "boutons navigation"]
    },
    "gnome.terminal-chrome": {
      "labelFr": "Chrome terminal (Ptyxis)",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/terminal-ptyxis.base.css"],
      "chromeProvider": "terminal-gnome",
      "states": ["default", "preferences-dialog"],
      "acquisitionVm": ["headerbar CSD", "palette couleurs", "onglets"]
    },
    "gnome.software-grid": {
      "labelFr": "Grille logiciels / catégories",
      "higUrl": "https://developer.gnome.org/hig/patterns/containers/grid-views.html",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/update_manager_gnome.base.css"],
      "capsuleSelectors": [".gnome-software__grid", ".gnome-software__card"],
      "states": ["explore", "installed", "updates"],
      "acquisitionVm": ["tuiles app", "badge mise à jour", "barre recherche"]
    },
    "gnome.media-viewer": {
      "labelFr": "Visionneuse document / image",
      "capsuleCss": [
        "usr/share/capsuleos/linux/apps/style/visionneur_images.base.css",
        "usr/share/capsuleos/linux/apps/style/visionneur_pdf.base.css"
      ],
      "capsuleSelectors": [".viewer-app__toolbar", ".viewer-app__canvas"],
      "states": ["zoom-fit", "sidebar-thumbnails"],
      "acquisitionVm": ["barre zoom", "miniatures", "mode sombre"]
    },
    "gnome.calendar-grid": {
      "labelFr": "Grille calendrier",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/calendar.base.css"],
      "states": ["month-view", "week-view", "event-popover"],
      "acquisitionVm": ["cellules jour", "événement", "navigation mois"]
    },
    "gnome.clocks-face": {
      "labelFr": "Cadran / minuterie",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/clocks.base.css"],
      "states": ["world-clock", "alarm", "timer", "stopwatch"],
      "acquisitionVm": ["onglets type horloge", "cadran", "liste fuseaux"]
    },
    "gnome.monospace-editor": {
      "labelFr": "Éditeur texte (Text Editor)",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/text_editor.base.css"],
      "capsuleSelectors": [".xed-app__menubar", ".xed-app__editor"],
