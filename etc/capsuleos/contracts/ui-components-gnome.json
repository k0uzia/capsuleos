    },
    "gnome.chart-disk-usage": {
      "labelFr": "Visualisation usage disque",
      "capsuleCss": ["usr/share/capsuleos/linux/apps/style/baobab.base.css"],
      "states": ["treemap", "list-mounts"],
      "acquisitionVm": ["treemap couleurs", "liste volumes gauche"]
    },
    "gnome.system-metrics": {
      "labelFr": "Graphiques système",
