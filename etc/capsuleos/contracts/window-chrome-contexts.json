{
  "version": 1,
  "description": "Contextes chrome fenêtre par toolkit DE. Le runtime résout via CapsuleWindowHeaderContext ; les profils skin peuvent surcharger via CAPSULE_WINDOW_CHROME_CONTEXT.",
  "explorerSlotId": "nemo",
  "toolkits": {
    "cinnamon": {
      "displayName": "Cinnamon / Muffin SSD",
      "headerLayout": "capsule",
      "headerIconPack": "cinnamon",
      "behaviorsModule": "cinnamon-window-behaviors.js",
      "explorerTemplates": ["nemo"],
      "explorerChromeProvider": "nemo",
      "explorerDragMode": "unified-titlebar",
      "slotChromeProviders": {
        "default": "cinnamon"
      }
    },
    "gnome": {
      "displayName": "GNOME / Mutter SSD",
      "headerLayout": "capsule",
      "headerIconPack": "gnome",
      "behaviorsModule": "gnome-window-behaviors.js",
      "explorerTemplates": ["nemo-gnome", "nautilus"],
      "explorerChromeProvider": "nemo-gnome",
      "explorerDragMode": "app-headerbar-passthrough",
      "slotChromeProviders": {
        "firefox": "firefox-gnome",
        "terminal": "terminal-gnome",
        "default": "default"
      }
    },
    "kde": {
      "displayName": "KDE Plasma / Breeze",
      "headerLayout": "capsule",
      "headerIconPack": "kde-breeze",
      "behaviorsModule": null,
      "explorerTemplates": ["dolphin"],
      "explorerChromeProvider": "dolphin",
      "explorerDragMode": "window-header",
      "slotChromeProviders": {
        "default": "default"
      }
    },
    "cosmic": {
      "displayName": "COSMIC",
      "headerLayout": "capsule",
      "headerIconPack": "cosmic",
      "behaviorsModule": null,
      "explorerTemplates": ["nemo-cosmic", "nautilus-cosmic"],
      "explorerChromeProvider": "nemo-gnome",
      "explorerDragMode": "app-headerbar-passthrough",
      "slotChromeProviders": {
        "terminal": "terminal-cosmic",
        "default": "default"
      }
    }
  },
  "templateToToolkit": {
    "nemo": "cinnamon",
    "nemo-gnome": "gnome",
    "nautilus": "gnome",
    "dolphin": "kde",
    "nemo-cosmic": "cosmic",
    "nautilus-cosmic": "cosmic"
  }
}
