{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/approve-formal-lab.sh",
        "timeout": 5
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-remote-sync.sh",
        "timeout": 20
      },
      {
        "command": ".cursor/hooks/session-formal-context.sh",
        "timeout": 8
      }
    ]
  }
}
