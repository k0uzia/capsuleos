{
  "registryId": "linux-mint",
  "slot": "file_roller",
  "version": 1,
  "collectedAt": "2026-06-09T16:00:00Z",
  "source": "linux-mint-file-roller-vm.json+smoke-mint-file-roller",
  "workflow": {
    "cycle": "VM inventaire → file-roller-scenarios.json → impl file-roller.js → run-mint-file-roller-campaign.mjs → checkpoint GO/NO-GO",
    "smokeGate": "usr/lib/capsuleos/tools/lab/smoke-mint-file-roller-fidelity.mjs",
    "checklist": "node usr/lib/capsuleos/tools/lab/print-mint-app-p1-checklist.mjs file_roller"
  },
  "vm": {
    "host": "<lab-inventory:linux-mint>",
    "package": "file-roller 43.0+mint1+wilma",
    "vmJson": "root/docs/inventaires/linux-mint-file-roller-vm.json",
    "vmDoc": "root/docs/inventaires/linux-mint-file-roller-vm.md"
  },
  "scenarios": [
    {
      "id": "menu.open",
      "priority": "P0",
      "label": "Ouverture depuis menu Cinnamon",
      "dimension": "nav",
      "setup": { "openVia": "menu", "search": "d'archives" },
      "expect": {
        "winVisible": true,
        "appReady": true,
        "wmTitle": "Gestionnaire d'archives"
      }
    },
    {
      "id": "chrome.csd",
      "priority": "P0",
      "label": "Chrome Cinnamon — header WM visible",
      "dimension": "vis",
      "setup": { "openVia": "api" },
      "expect": {
        "chromeToolkit": "cinnamon",
        "chromeProvider": "cinnamon",
        "headerVisible": true,
        "headerDrag": true,
        "csdClass": false
      }
    },
    {
      "id": "empty.state",
      "priority": "P0",
      "label": "État vide — accueil File Roller",
      "dimension": "data",
      "setup": { "openVia": "api", "resetEmpty": true },
      "expect": {
        "emptyVisible": true,
        "navHidden": true,
        "extractDisabled": true
      },
      "vmNote": "VM : titre « Gestionnaire d'archives », zone vide centrée"
    },
    {
      "id": "menu.open-demo",
      "priority": "P1",
      "label": "Menu hamburger → Ouvrir l'exemple",
      "dimension": "int",
      "setup": { "openVia": "api", "resetEmpty": true },
      "action": { "type": "click", "selector": "[data-fr-action=\"menu\"]" },
      "action2": { "type": "click", "selector": "[data-fr-menu=\"open-demo\"]" },
      "expect": {
        "wmTitle": "demo.zip",
        "navVisible": true,
        "rowCount": 1,
        "firstName": "demo.txt",
        "firstSize": "11 octets",
        "path": "/",
        "extractEnabled": true
      },
      "rv": "Rv₁ — titre WM et liste synchronisés après ouverture archive"
    },
    {
      "id": "rv.close-archive",
      "priority": "P1",
      "label": "Fermer archive → retour état vide",
      "dimension": "int",
      "setup": { "openVia": "api", "openDemo": true },
      "action": { "type": "click", "selector": "[data-fr-menu=\"close\"]", "preOpenMenu": true },
      "expect": {
        "emptyVisible": true,
        "wmTitle": "Gestionnaire d'archives",
        "navHidden": true,
        "extractDisabled": true
      },
      "rv": "Rv₁ — showEmptyState après close"
    },
    {
      "id": "rv.search-filter",
      "priority": "P1",
      "label": "Recherche filtre les entrées",
      "dimension": "int",
      "setup": { "openVia": "api", "openDemo": true },
      "action": { "type": "click", "selector": "[data-fr-action=\"search\"]" },
      "action2": { "type": "fill", "selector": "#fr-search-input", "value": "nomatch-zzz" },
      "expect": { "rowCount": 0 },
      "action3": { "type": "fill", "selector": "#fr-search-input", "value": "" },
      "expectAfter3": { "rowCount": 1 },
      "rv": "Rv₁ — renderEntries après input search"
    },
    {
      "id": "action.extract",
      "priority": "P1",
      "label": "Extraction simulée — statut barre",
      "dimension": "int",
      "setup": { "openVia": "api", "openDemo": true },
      "action": { "type": "click", "selector": "[data-fr-action=\"extract\"]" },
      "expect": {
        "statusContains": "Extraction simulée"
      }
    },
    {
      "id": "geometry.window",
      "priority": "P1",
      "label": "Géométrie fenêtre VM ± tolérance",
      "dimension": "vis",
      "setup": { "openVia": "api", "openDemo": true, "resetEmpty": false },
      "expect": {
        "winWidthMin": 644,
        "winWidthMax": 660,
        "winHeightMin": 571,
        "winHeightMax": 587,
        "headerbarHMin": 42,
        "headerbarHMax": 50,
        "colNamePctMin": 40,
        "colNamePctMax": 44
      },
      "vmNote": "VM layoutPx : 652×579, headerbar 46, colonne nom 42 %"
    },
    {
      "id": "window.drag",
      "priority": "P1",
      "label": "Déplacement fenêtre via barre WM",
      "dimension": "vis",
      "setup": { "openVia": "api" },
      "action": { "type": "drag-header", "deltaX": 70 },
      "expect": { "dragMoved": true }
    }
  ]
}
