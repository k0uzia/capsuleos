{
  "id": "nautilus-headerbar-gnome",
  "app": "org.gnome.Nautilus",
  "slotCapsule": "nemo",
  "template": "nemo-gnome",
  "reference": "https://doc.ubuntu-fr.org/nautilus",
  "controls": [
    {
      "id": "plate-search",
      "selector": ".nautilus-app__plate-search",
      "labelFr": "Recherche globale (plateau titre)",
      "vmBehavior": "Focus barre recherche / emplacement",
      "capsuleHandler": "focusSearchInput",
      "priority": "P0"
    },
    {
      "id": "sidebar-menu",
      "selector": ".nautilus-app__sidebar-menu-btn",
      "labelFr": "Menu principal ☰",
      "vmBehavior": "Popover : nouveau dossier, onglet, actualiser, fichiers cachés, préférences",
      "capsuleHandler": "#nautilus-main-menu",
      "priority": "P0"
    },
    {
      "id": "precedent",
      "selector": "#precedent",
      "labelFr": "Précédent",
      "vmBehavior": "Historique arrière",
      "capsuleHandler": "goToPreviousDirectory",
      "priority": "P0"
    },
    {
      "id": "suivant",
      "selector": "#suivant",
      "labelFr": "Suivant",
      "vmBehavior": "Historique avant",
      "capsuleHandler": "goToNextDirectory",
      "priority": "P0"
    },
    {
      "id": "search-input",
      "selector": "#nemo-search-input",
      "labelFr": "Barre recherche / emplacement",
      "vmBehavior": "Recherche locale ; / ou ~ → navigation",
      "capsuleHandler": "searchQuery + resolvePathFromLocationInput",
      "priority": "P0"
    },
    {
      "id": "search-filter",
      "selector": ".nautilus-app__search-filter",
      "labelFr": "Filtres de recherche",
      "vmBehavior": "Filtrer par type (tous, dossiers, fichiers)",
      "capsuleHandler": "#nautilus-search-filter-menu",
      "priority": "P1"
    },
    {
      "id": "search-info",
      "selector": ".nautilus-app__search-info",
      "labelFr": "Emplacement / informations",
      "vmBehavior": "Mode adresse (Ctrl+L) ou propriétés dossier",
      "capsuleHandler": "toggleLocationBarMode / openExplorerProperties",
      "priority": "P1"
    },
    {
      "id": "new-folder",
      "selector": ".nautilus-app__new-folder-btn",
      "labelFr": "Nouveau dossier",
      "vmBehavior": "Créer dossier dans l’emplacement courant",
      "capsuleHandler": "createNewFolderInCurrentDirectory",
      "priority": "P0"
    },
    {
      "id": "view-list",
      "selector": "[data-view-mode=\"list\"]",
      "labelFr": "Vue liste",
      "vmBehavior": "Ctrl+2",
      "capsuleHandler": "setFileExplorerViewMode('list')",
      "priority": "P0"
    },
    {
      "id": "view-icons",
      "selector": "[data-view-mode=\"icons\"]",
      "labelFr": "Vue icônes",
      "vmBehavior": "Ctrl+1",
      "capsuleHandler": "setFileExplorerViewMode('icons')",
      "priority": "P0"
    },
    {
      "id": "view-menu",
      "selector": ".nautilus-app__view-menu-btn",
      "labelFr": "Autres vues",
      "vmBehavior": "Vue compacte, tri",
      "capsuleHandler": "#nautilus-view-menu",
      "priority": "P1"
    },
    {
      "id": "window-close",
      "selector": ".nautilus-app__window-close",
      "labelFr": "Fermer",
      "vmBehavior": "Fermer la fenêtre",
      "capsuleHandler": "window close chrome",
      "priority": "P0"
    }
  ]
}
