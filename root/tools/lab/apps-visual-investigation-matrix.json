{
  "version": 2,
  "registryId": "linux-kde-neon",
  "description": "Matrice enquête visuelle apps — acquisitionOrder ui-components-gnome.json",
  "uiComponentsContract": "etc/capsuleos/contracts/ui-components-gnome.json",
  "investigations": [
    {
      "controlId": "themes",
      "labelFr": "Configuration du système",
      "vmDesktop": "systemsettings.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "sidebar-panels",
        "wifi-row",
        "display-panel",
        "about-panel"
      ],
      "launch": "gtk-launch systemsettings.desktop"
    },
    {
      "controlId": "update_manager",
      "labelFr": "Discover",
      "vmDesktop": "org.kde.discover.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "explore-grid",
        "featured-hero",
        "category-heroes",
        "updates-banner",
        "app-detail",
        "categories"
      ],
      "launch": "gtk-launch org.kde.discover.desktop"
    },
    {
      "controlId": "nemo",
      "labelFr": "Dolphin",
      "vmDesktop": "org.kde.dolphin.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "sidebar",
        "column-headers",
        "pathbar",
        "context-menu-item",
        "context-menu-background",
        "trash"
      ],
      "launch": "nohup dolphin --new-window \"$HOME\" >/dev/null 2>&1 & disown"
    },
    {
      "controlId": "firefox",
      "labelFr": "Firefox",
      "vmDesktop": "firefox.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "tab-bar",
        "url-bar",
        "bookmarks",
        "menu-hamburger"
      ],
      "launch": "gtk-launch firefox.desktop"
    },
    {
      "controlId": "text_editor",
      "labelFr": "Kate",
      "vmDesktop": "org.kde.kate.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "menubar",
        "editor-area",
        "status-line",
        "open-dialog"
      ],
      "launch": "gtk-launch org.kde.kate.desktop"
    },
    {
      "controlId": "terminal",
      "labelFr": "Konsole",
      "vmDesktop": "org.kde.konsole.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "headerbar",
        "tab-strip",
        "prompt-colors",
        "preferences"
      ],
      "launch": "gtk-launch org.kde.konsole.desktop"
    },
    {
      "controlId": "lecteur_multimedia",
      "labelFr": "Lecteur vidéo",
      "vmDesktop": "vlc.desktop",
      "parityPriority": "P0",
      "componentShots": [
        "transport-controls",
        "playlist",
        "album-art"
      ],
      "launch": "gtk-launch vlc.desktop"
    }
  ]
}
