{
  "version": 1,
  "description": "Assets ground truth Paramètres GNOME — AlmaLinux 10 (fonds VM).",
  "registry": "linux-alma",
  "vendor": "alma",
  "pullScript": "root/tools/lab/pull-vm-assets.sh",
  "sourceTraceFile": "usr/share/capsuleos/assets/images/vendors/alma/SOURCE-VM.txt",
  "gsettingsSources": [
    {
      "id": "desktop-background-uri",
      "schema": "org.gnome.desktop.background",
      "key": "picture-uri",
      "note": "Fond actif — almalinux-day.jpg sur VM"
    },
    {
      "id": "desktop-background-uri-dark",
      "schema": "org.gnome.desktop.background",
      "key": "picture-uri-dark",
      "note": "Fond variante nuit — almalinux-night.jpg"
    }
  ],
  "assets": [
    {
      "id": "wallpaper-almalinux-day",
      "category": "wallpaper",
      "controlId": "wallpaper",
      "label": "AlmaLinux (jour)",
      "vmPath": "/usr/share/backgrounds/almalinux-day.jpg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/alma/wallpaper/almalinux-day.jpg",
      "transcodeFromVm": false
    },
    {
      "id": "wallpaper-almalinux-night",
      "category": "wallpaper",
      "controlId": "wallpaper",
      "label": "AlmaLinux (nuit)",
      "vmPath": "/usr/share/backgrounds/almalinux-night.jpg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/alma/wallpaper/almalinux-night.jpg",
      "transcodeFromVm": false
    },
    {
      "id": "watermark-fedora-logo-dark",
      "category": "watermark",
      "controlId": "wallpaper",
      "label": "Filigrane bureau (sombre)",
      "vmPath": "/usr/share/almalinux-logos/fedora_logo_darkbackground.svg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/alma/watermark/fedora_logo_darkbackground.svg"
    },
    {
      "id": "watermark-fedora-logo-light",
      "category": "watermark",
      "controlId": "wallpaper",
      "label": "Filigrane bureau (clair)",
      "vmPath": "/usr/share/almalinux-logos/fedora_logo_lightbackground.svg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/alma/watermark/fedora_logo_lightbackground.svg"
    }
  ]
}
