{
  "version": 1,
  "description": "Assets ground truth Paramètres GNOME — Fedora 44 Workstation.",
  "registry": "linux-fedora",
  "vendor": "fedora",
  "pullScript": "root/tools/lab/pull-vm-assets.sh",
  "sourceTraceFile": "usr/share/capsuleos/assets/images/vendors/fedora/SOURCE-VM.txt",
  "gsettingsSources": [
    {
      "id": "desktop-background-uri",
      "schema": "org.gnome.desktop.background",
      "key": "picture-uri",
      "note": "Fond actif — f44-01-day.jxl sur VM F44"
    },
    {
      "id": "desktop-background-uri-dark",
      "schema": "org.gnome.desktop.background",
      "key": "picture-uri-dark",
      "note": "Fond variante nuit — f44-01-night.jxl"
    }
  ],
  "assets": [
    {
      "id": "wallpaper-f44-day",
      "category": "wallpaper",
      "controlId": "wallpaper",
      "label": "Fedora 44 (jour)",
      "vmPath": "/usr/share/backgrounds/f44/default/f44-01-day.jxl",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/fedora/wallpaper/f44-01-day.webp",
      "transcodeFromVm": true,
      "note": "CapsuleOS : PNG converti depuis JXL VM (navigateur)"
    },
    {
      "id": "wallpaper-f44-night",
      "category": "wallpaper",
      "controlId": "wallpaper",
      "label": "Fedora 44 (nuit)",
      "vmPath": "/usr/share/backgrounds/f44/default/f44-01-night.jxl",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/fedora/wallpaper/f44-01-night.webp",
      "transcodeFromVm": true
    },
    {
      "id": "watermark-fedora-logo-dark",
      "category": "watermark",
      "controlId": "wallpaper",
      "label": "Filigrane bureau (sombre)",
      "vmPath": "/usr/share/fedora-logos/fedora_logo_darkbackground.svg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/fedora/watermark/fedora_logo_darkbackground.svg"
    },
    {
      "id": "watermark-fedora-light",
      "category": "watermark",
      "controlId": "wallpaper",
      "label": "Filigrane bureau (clair)",
      "vmPath": "/usr/share/fedora-logos/fedora_lightbackground.svg",
      "capsulePath": "usr/share/capsuleos/assets/images/vendors/fedora/watermark/fedora_lightbackground.svg"
    }
  ]
