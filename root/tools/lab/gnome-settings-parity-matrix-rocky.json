{
  "version": 1,
  "description": "Matrice panneaux gnome-control-center ↔ CapsuleOS — Rocky Linux 10 / GNOME 47.",
  "registry": "linux-rocky",
  "panels": [
    {
      "id": "wifi",
      "capsulePanel": "wifi",
      "label": "Wi-Fi",
      "gccArgv": ["wifi"],
      "titleHints": ["Wi-Fi", "WiFi", "Réseau sans fil"],
      "controls": [
        { "id": "wifi", "type": "switch", "capsuleKey": "gnome-wifi-enabled", "source": "nmcli-wifi" }
      ],
      "gsettings": []
    },
    {
      "id": "network",
      "capsulePanel": "network",
      "label": "Réseau",
      "gccArgv": ["network"],
      "titleHints": ["Réseau", "Network", "Wired"],
      "controls": [
        { "id": "network-identity", "type": "select", "capsuleKey": "gnome-network-identity", "source": "simulated", "note": "NM ipv4.method" }
      ],
      "gsettings": []
    },
    {
      "id": "bluetooth",
      "capsulePanel": "bluetooth",
      "label": "Bluetooth",
      "gccArgv": ["bluetooth"],
      "titleHints": ["Bluetooth"],
      "controls": [
        { "id": "bluetooth", "type": "switch", "capsuleKey": "gnome-bluetooth-enabled", "source": "nmcli-bluetooth" }
      ],
      "gsettings": []
    },
    {
      "id": "appearance",
      "capsulePanel": "appearance",
      "label": "Apparence",
      "gccArgv": ["appearance", "color"],
      "titleHints": ["Apparence", "Appearance", "Couleurs"],
      "controls": [
        { "id": "theme", "type": "theme", "capsuleKey": "mint-theme", "schema": "org.gnome.desktop.interface", "key": "color-scheme", "map": "colorScheme" },
        { "id": "accent", "type": "accent", "capsuleKey": "gnome-accent", "schema": "org.gnome.desktop.interface", "key": "accent-color", "map": "accentColor" }
      ],
      "gsettings": [
        ["org.gnome.desktop.interface", "color-scheme"],
        ["org.gnome.desktop.interface", "accent-color"],
        ["org.gnome.desktop.interface", "gtk-theme"]
      ]
    },
    {
      "id": "background",
      "capsulePanel": "background",
      "label": "Arrière-plan",
      "gccArgv": ["background"],
      "titleHints": ["Arrière-plan", "Background", "Fond d'écran"],
      "controls": [
        { "id": "wallpaper", "type": "wallpaper", "capsuleKey": "gnome-wallpaper", "schema": "org.gnome.desktop.background", "key": "picture-uri", "map": "wallpaperUri" }
      ],
      "gsettings": [
        ["org.gnome.desktop.background", "picture-uri"],
        ["org.gnome.desktop.background", "picture-uri-dark"]
      ]
    },
    {
      "id": "notifications",
      "capsulePanel": "notifications",
      "label": "Notifications",
      "gccArgv": ["notifications"],
      "titleHints": ["Notifications"],
      "controls": [
        { "id": "notifications", "type": "switch", "capsuleKey": "gnome-notifications-enabled", "schema": "org.gnome.desktop.notifications", "key": "show-banners", "map": "boolOnOff" },
        { "id": "lock-notifications", "type": "switch", "capsuleKey": "gnome-lock-notifications", "schema": "org.gnome.desktop.notifications", "key": "show-in-lock-screen", "map": "boolOnOff" },
        { "id": "dnd", "type": "switch", "capsuleKey": "gnome-dnd-enabled", "schema": "org.capsuleos.gnome.shell", "key": "dnd-enabled", "map": "boolOnOff", "source": "simulated-gsettings", "note": "Session shell GNOME — schéma CapsuleOS miroir lab (pas de clé gsettings VM unique RL10)" }
      ],
      "gsettings": [
        ["org.gnome.desktop.notifications", "show-banners"],
        ["org.gnome.desktop.notifications", "show-in-lock-screen"]
      ]
    },
    {
      "id": "search",
      "capsulePanel": "search",
      "label": "Recherche",
      "gccArgv": ["search"],
      "titleHints": ["Recherche", "Search"],
      "controls": [
        { "id": "search-history", "type": "switch", "capsuleKey": "gnome-search-history", "schema": "org.gnome.desktop.search-providers", "key": "disabled", "map": "searchProviderToggle", "providerId": "org.gnome.History" },
        { "id": "search-files", "type": "switch", "capsuleKey": "gnome-search-files", "schema": "org.gnome.desktop.search-providers", "key": "disabled", "map": "searchProviderToggle", "providerId": "org.gnome.Nautilus" },
        { "id": "search-apps", "type": "switch", "capsuleKey": "gnome-search-apps", "source": "simulated", "note": "Shell apps toujours actif" },
        { "id": "search-calculator", "type": "switch", "capsuleKey": "gnome-search-calculator", "schema": "org.gnome.desktop.search-providers", "key": "disabled", "map": "searchProviderToggle", "providerId": "org.gnome.Calculator" }
      ],
      "gsettings": [
        ["org.gnome.desktop.search-providers", "disabled"]
      ]
    },
    {
      "id": "multitasking",
      "capsulePanel": "multitasking",
      "label": "Multitâche",
      "gccArgv": ["multitasking"],
      "titleHints": ["Multitâche", "Multitasking"],
      "controls": [
        { "id": "dynamic-workspaces", "type": "select", "capsuleKey": "gnome-dynamic-workspaces", "schema": "org.gnome.mutter", "key": "dynamic-workspaces", "map": "enabledLabelFr" },
        { "id": "hot-corner", "type": "select", "capsuleKey": "gnome-hot-corner", "schema": "org.gnome.desktop.interface", "key": "enable-hot-corners", "map": "enabledLabelFr" },
        { "id": "apps-all-workspaces", "type": "select", "capsuleKey": "gnome-apps-all-workspaces", "schema": "org.gnome.shell.app-switcher", "key": "current-workspace-only", "map": "workspaceOnlyInverted" }
      ],
      "gsettings": [
        ["org.gnome.mutter", "dynamic-workspaces"],
        ["org.gnome.desktop.interface", "enable-hot-corners"],
        ["org.gnome.shell.app-switcher", "current-workspace-only"]
      ]
    },
    {
      "id": "sound",
      "capsulePanel": "sound",
      "label": "Son",
      "gccArgv": ["sound"],
      "titleHints": ["Son", "Sound"],
      "controls": [
        { "id": "sound-alert", "type": "select", "capsuleKey": "gnome-sound-alert", "schema": "org.gnome.desktop.sound", "key": "theme-name", "map": "soundTheme" },
        { "id": "volume", "type": "slider", "capsuleKey": "mint-volume", "schema": "org.gnome.settings-daemon.plugins.media-keys", "key": "volume-step", "map": "volumeStepNote" }
      ],
      "gsettings": [
        ["org.gnome.desktop.sound", "theme-name"],
        ["org.gnome.desktop.sound", "event-sounds"],
        ["org.gnome.settings-daemon.plugins.media-keys", "volume-step"]
      ]
    },
    {
      "id": "power",
      "capsulePanel": "power",
      "label": "Alimentation",
      "gccArgv": ["power"],
      "titleHints": ["Alimentation", "Power"],
      "controls": [
        { "id": "power-mode", "type": "select", "capsuleKey": "gnome-power-mode", "schema": "org.capsuleos.gnome.power", "key": "active-profile", "map": "powerProfile", "source": "simulated-gsettings", "note": "powerprofilesctl — schéma CapsuleOS miroir lab" },
        { "id": "power-dim", "type": "select", "capsuleKey": "gnome-power-dim-screen", "schema": "org.gnome.settings-daemon.plugins.power", "key": "sleep-inactive-ac-timeout", "map": "powerDimTimeout" },
        { "id": "power-sleep", "type": "select", "capsuleKey": "gnome-power-sleep", "schema": "org.gnome.settings-daemon.plugins.power", "key": "sleep-inactive-ac-type", "map": "powerSleepType" }
      ],
      "gsettings": [
        ["org.gnome.settings-daemon.plugins.power", "sleep-inactive-ac-timeout"],
        ["org.gnome.settings-daemon.plugins.power", "sleep-inactive-ac-type"]
      ]
    },
    {
      "id": "displays",
      "capsulePanel": "displays",
      "label": "Écrans",
      "gccArgv": ["display", "displays"],
      "titleHints": ["Écrans", "Displays", "Display"],
      "controls": [
        { "id": "display-scale", "type": "select", "capsuleKey": "gnome-display-scale", "schema": "org.gnome.desktop.interface", "key": "text-scaling-factor", "map": "textScalingPercent" },
        { "id": "night-light", "type": "switch", "capsuleKey": "gnome-night-light", "schema": "org.gnome.settings-daemon.plugins.color", "key": "night-light-enabled", "map": "boolOnOff" }
      ],
      "gsettings": [
        ["org.gnome.desktop.interface", "text-scaling-factor"],
        ["org.gnome.settings-daemon.plugins.color", "night-light-enabled"]
      ]
    },
    {
      "id": "mouse",
      "capsulePanel": "mouse",
      "label": "Souris et pavé tactile",
      "gccArgv": ["mouse"],
      "titleHints": ["Souris", "Mouse", "pavé tactile"],
      "controls": [
        { "id": "mouse-handedness", "type": "select", "capsuleKey": "gnome-mouse-handedness", "schema": "org.gnome.desktop.peripherals.mouse", "key": "left-handed", "map": "mouseHandedness" },
        { "id": "pointer-speed", "type": "slider", "capsuleKey": "gnome-pointer-speed", "schema": "org.gnome.desktop.peripherals.mouse", "key": "speed", "map": "pointerSpeedPercent" },
        { "id": "touchpad", "type": "switch", "capsuleKey": "gnome-touchpad-enabled", "schema": "org.gnome.desktop.peripherals.touchpad", "key": "send-events", "map": "touchpadEnabled" },
        { "id": "tap-to-click", "type": "switch", "capsuleKey": "gnome-tap-to-click", "schema": "org.gnome.desktop.peripherals.touchpad", "key": "tap-to-click", "map": "boolOnOff" },
        { "id": "scroll-direction", "type": "select", "capsuleKey": "gnome-scroll-direction", "schema": "org.gnome.desktop.peripherals.touchpad", "key": "natural-scroll", "map": "scrollDirection" }
      ],
      "gsettings": [
        ["org.gnome.desktop.peripherals.mouse", "left-handed"],
        ["org.gnome.desktop.peripherals.mouse", "speed"],
        ["org.gnome.desktop.peripherals.touchpad", "send-events"],
        ["org.gnome.desktop.peripherals.touchpad", "tap-to-click"],
        ["org.gnome.desktop.peripherals.touchpad", "natural-scroll"]
      ]
    },
    {
      "id": "keyboard",
      "capsulePanel": "keyboard",
      "label": "Clavier",
      "gccArgv": ["keyboard"],
      "titleHints": ["Clavier", "Keyboard"],
      "controls": [
        { "id": "keyboard-layout", "type": "select", "capsuleKey": "gnome-keyboard-layout", "schema": "org.gnome.desktop.input-sources", "key": "sources", "map": "keyboardLayoutFr" },
        { "id": "keyboard-repeat", "type": "select", "capsuleKey": "gnome-keyboard-repeat-delay", "schema": "org.gnome.desktop.peripherals.keyboard", "key": "delay", "map": "keyboardDelayMs" }
      ],
      "gsettings": [
        ["org.gnome.desktop.input-sources", "sources"],
        ["org.gnome.desktop.peripherals.keyboard", "delay"]
      ]
    },
    {
      "id": "printers",
      "capsulePanel": "printers",
      "label": "Imprimantes",
      "gccArgv": ["printers"],
      "titleHints": ["Imprimantes", "Printers"],
      "controls": [],
      "gsettings": []
    },
    {
      "id": "accessibility",
      "capsulePanel": "accessibility",
      "label": "Accessibilité",
      "gccArgv": ["universal-access", "accessibility"],
      "titleHints": ["Accessibilité", "Accessibility", "Universal Access"],
      "controls": [
        { "id": "contrast", "type": "contrast", "capsuleKey": "mint-contrast-mode", "schema": "org.gnome.desktop.interface", "key": "gtk-theme", "map": "gtkHighContrast" },
        { "id": "font-scale", "type": "font-scale", "capsuleKey": "mint-font-scale", "schema": "org.gnome.desktop.interface", "key": "text-scaling-factor", "map": "fontScalePercent" }
      ],
      "gsettings": [
        ["org.gnome.desktop.interface", "gtk-theme"],
        ["org.gnome.desktop.interface", "text-scaling-factor"]
      ]
    },
    {
      "id": "privacy",
      "capsulePanel": "privacy",
      "label": "Confidentialité",
      "gccArgv": ["privacy"],
      "titleHints": ["Confidentialité", "Privacy"],
      "controls": [
        { "id": "location", "type": "switch", "capsuleKey": "gnome-privacy-location", "source": "simulated" },
        { "id": "camera", "type": "switch", "capsuleKey": "gnome-privacy-camera", "schema": "org.gnome.desktop.privacy", "key": "disable-camera", "map": "privacyInverted" },
        { "id": "microphone", "type": "switch", "capsuleKey": "gnome-privacy-microphone", "schema": "org.gnome.desktop.privacy", "key": "disable-microphone", "map": "privacyInverted" },
        { "id": "auto-lock", "type": "switch", "capsuleKey": "gnome-auto-lock", "schema": "org.gnome.desktop.screensaver", "key": "lock-enabled", "map": "boolOnOff" },
        { "id": "lock-delay", "type": "select", "capsuleKey": "gnome-lock-delay", "schema": "org.gnome.desktop.screensaver", "key": "lock-delay", "map": "lockDelayFr" }
      ],
      "gsettings": [
        ["org.gnome.desktop.privacy", "disable-camera"],
        ["org.gnome.desktop.privacy", "disable-microphone"],
        ["org.gnome.desktop.screensaver", "lock-enabled"],
        ["org.gnome.desktop.screensaver", "lock-delay"]
      ]
    },
    {
      "id": "sharing",
      "capsulePanel": "sharing",
      "label": "Partage",
      "gccArgv": ["sharing"],
      "titleHints": ["Partage", "Sharing"],
      "controls": [
        { "id": "sharing", "type": "switch", "capsuleKey": "gnome-sharing-enabled", "source": "simulated" },
        { "id": "file-sharing", "type": "switch", "capsuleKey": "gnome-file-sharing", "source": "simulated" },
        { "id": "screen-sharing", "type": "switch", "capsuleKey": "gnome-screen-sharing", "source": "simulated" }
      ],
      "gsettings": []
    },
    {
      "id": "about",
      "capsulePanel": "about",
      "label": "À propos",
      "gccArgv": ["info", "about"],
      "titleHints": ["À propos", "About", "Details"],
      "controls": [],
      "gsettings": []
    }
  ]
}
