      "vmObservation": "Teinte ambiante chaude ; barre supérieure souvent exclue du filtre.",
      "transition": {
        "type": "ease-in-out",
        "durationMs": 1000,
        "property": "color-temperature",
        "notes": "gsd-color anime la température sur ~1 s."
      },
      "capsuleHook": {
        "dataset": "nightLight",
        "css": "gnome-shell-preferences.base.css",
        "selector": "html[data-night-light=\"on\"]"
