{
  "version": 1,
  "description": "Grille enquête visuelle — Fedora 44 / GNOME Shell 50.",
  "registry": "linux-fedora",
  "investigations": [
    {
      "controlId": "theme",
      "capsulePanel": "appearance",
      "label": "Thème clair / sombre",
      "surfaces": [
        "desktop",
        "top-bar",
        "overview",
        "window-chrome",
        "settings-app"
      ],
      "vmObservation": "Bascule globale GTK + Shell ; fond d'écran peut suivre variante jour/nuit si lié.",
      "transition": {
        "type": "cross-fade",
        "durationMs": 300,
        "easing": "ease-out",
        "notes": "Adwaita : transition courte sur widgets ; fond peut être instantané ou différé."
      },
      "capsuleHook": {
        "dataset": "theme",
        "css": [
          "themes_gnome.base.css",
          "home/RedHat/Fedora/style/gnome-shell/tokens.css"
        ],
        "event": "capsule:theme-changed"
      },
      "officialDocs": [
        {
          "title": "GNOME Help — Appearance",
          "url": "https://help.gnome.org/users/gnome-help/stable/prefs-user.html"
        },
        {
          "title": "interface color-scheme",
          "url": "https://gitlab.gnome.org/GNOME/gsettings-desktop-schemas"
        }
      ],
      "investigationSteps": [
        "gcc Apparence → clair/sombre",
        "capture bureau T+0 / T+0.5s",
        "noter si top bar et fenêtres changent ensemble",
        "comparer Capsule reload"
      ],
      "parityPriority": "P0"
    },
    {
      "controlId": "accent",
      "capsulePanel": "appearance",
      "label": "Couleur d'accent",
      "surfaces": [
