      "vmObservation": "Accent appliqué aux sélections, liens, switches actifs, tuiles QS.",
      "transition": {
        "type": "instant",
        "durationMs": 0,
        "property": "accent-color"
      },
      "capsuleHook": {
        "dataset": "gnomeAccent",
        "cssVars": [
          "--menu-accent",
          "--gcc-accent"
        ],
        "event": "capsule:accent-changed"
