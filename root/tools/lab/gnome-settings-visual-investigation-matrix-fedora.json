      "officialDocs": [
        {
          "title": "HIG — Style",
          "url": "https://developer.gnome.org/hig/"
        },
        {
          "title": "libadwaita accent",
          "url": "https://gnome.pages.gitlab.gnome.org/libadwaita/doc/main/"
        }
      ],
      "investigationSteps": [
        "changer puce accent",
        "capture Paramètres + QS ouvert",
        "pipette couleur hex sur switch actif"
      ],
      "parityPriority": "P1"
    },
