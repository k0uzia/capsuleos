{
  "version": 1,
  "description": "Previews KCM Couleurs — générés depuis /usr/share/color-schemes/*.colors (VM KDE Neon).",
  "registryId": "linux-kde-neon",
  "destDir": "usr/share/capsuleos/assets/images/vendors/neon/systemsettings/scheme-previews",
  "previewSize": { "width": 200, "height": 120 },
  "schemes": [
    {
      "vm": "/usr/share/color-schemes/BreezeClassic.colors",
      "out": "scheme-breeze-classic-vm.png",
      "labelFr": "Breeze Classique",
      "cssClass": "scheme-breeze-classic"
    },
    {
      "vm": "/usr/share/color-schemes/BreezeDark.colors",
      "out": "scheme-breeze-dark-vm.png",
      "labelFr": "Brise sombre",
      "cssClass": "scheme-breeze-dark"
    },
    {
      "vm": "/usr/share/color-schemes/BreezeLight.colors",
      "out": "scheme-breeze-light-vm.png",
      "labelFr": "Breeze clair",
      "cssClass": "scheme-breeze-light"
    },
    {
      "vm": "/usr/share/color-schemes/Oxygen.colors",
      "out": "scheme-oxygen-vm.png",
      "labelFr": "Oxygen",
      "cssClass": "scheme-oxygen"
    },
    {
      "vm": "/usr/share/color-schemes/OxygenCold.colors",
      "out": "scheme-oxygen-cold-vm.png",
      "labelFr": "Oxygen froid",
      "cssClass": "scheme-oxygen-cold"
    },
    {
      "vm": "/usr/share/color-schemes/OxygenDark.colors",
      "out": "scheme-oxygen-dark-vm.png",
      "labelFr": "Oxygen sombre",
      "cssClass": "scheme-oxygen-dark"
    }
  ],
  "plasmaThemes": [
    {
      "vm": "/usr/share/color-schemes/BreezeLight.colors",
      "out": "plasma-default-vm.png",
      "labelFr": "Breeze",
      "cssClass": "plasma-default",
      "note": "desktoptheme/default n'a pas colors — proxy BreezeLight (respecte schéma)"
    },
    {
      "vm": "/usr/share/plasma/desktoptheme/breeze-light/colors",
      "out": "plasma-breeze-light-vm.png",
      "labelFr": "Breeze clair",
      "cssClass": "plasma-breeze-light"
    },
    {
      "vm": "/usr/share/plasma/desktoptheme/breeze-dark/colors",
      "out": "plasma-breeze-dark-vm.png",
      "labelFr": "Breeze Sombre",
      "cssClass": "plasma-breeze-dark"
    },
    {
      "vm": "/usr/share/plasma/desktoptheme/oxygen/colors",
      "out": "plasma-oxygen-vm.png",
      "labelFr": "Oxygen",
      "cssClass": "plasma-oxygen-theme"
    },
    {
      "vm": "/usr/share/plasma/desktoptheme/air/colors",
      "out": "plasma-air-vm.png",
      "labelFr": "Air",
      "cssClass": "plasma-air"
    }
  ]
}
