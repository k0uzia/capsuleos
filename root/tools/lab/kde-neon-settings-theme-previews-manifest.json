{
  "version": 2,
  "description": "Theme-previews System Settings — assets originaux KDE (Plasma/LookAndFeel preview.png, pas capture écran).",
  "registryId": "linux-kde-neon",
  "destDir": "usr/share/capsuleos/assets/images/vendors/neon/systemsettings/theme-previews",
  "assets": [
    {
      "out": "hub-breeze-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents/previews/preview.png",
      "label": "Breeze — hub Paramétrage rapide"
    },
    {
      "out": "hub-dark-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezedark.desktop/contents/previews/preview.png",
      "label": "Breeze sombre"
    },
    {
      "out": "hub-auto-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezetwilight.desktop/contents/previews/preview.png",
      "label": "Automatique (Breeze clair-obscur LnF)"
    },
    {
      "out": "appearance-breeze-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents/previews/preview.png",
      "label": "Thème global Breeze"
    },
    {
      "out": "appearance-twilight-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezetwilight.desktop/contents/previews/preview.png",
      "label": "Breeze clair-obscur"
    },
    {
      "out": "appearance-dark-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezedark.desktop/contents/previews/preview.png",
      "label": "Breeze sombre"
    },
    {
      "out": "appearance-oxygen-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.oxygen/contents/previews/preview.png",
      "label": "Oxygen"
    },
    {
      "out": "colors-breeze-dark-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezedark.desktop/contents/previews/preview.png",
      "label": "Brise sombre — schéma BreezeDark (preview LnF associé)"
    },
    {
      "out": "colors-oxygen-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.oxygen/contents/previews/preview.png",
      "label": "Oxygen — schéma Oxygen.colors"
    },
    {
      "out": "colors-oxygen-cold-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.oxygenlight/contents/previews/preview.png",
      "label": "Oxygen froid — schéma OxygenCold.colors"
