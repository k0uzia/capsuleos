    {
      "out": "plasma-breeze-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents/previews/preview.png",
      "label": "Style Plasma Breeze"
    },
    {
      "out": "plasma-light-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents/previews/preview.png",
      "label": "Breeze clair (respecte schéma couleurs)"
    },
    {
      "out": "plasma-dark-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.breezedark.desktop/contents/previews/preview.png",
      "label": "Breeze Sombre"
    },
    {
      "out": "plasma-oxygen-vm.png",
      "vm": "/usr/share/plasma/look-and-feel/org.kde.oxygen/contents/previews/preview.png",
      "label": "Style Plasma Oxygen"
    }
