      "vmLaunch": "systemsettings kcm_access",
      "parityPriority": "P0",
      "geometry": { "width": 1060, "height": 808 }
    },
    {
      "controlId": "desktop-panel",
      "capsulePanel": "desktop",
      "label": "Panneau Bureau",
      "template": "systemsettings_kde_neon.html",
      "surfaces": ["settings-app", "desktop-icons"],
      "vmLaunch": "systemsettings kcm_desktoptheme",
      "parityPriority": "P0",
      "geometry": { "width": 1060, "height": 808 }
