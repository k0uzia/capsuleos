{
  "version": 2,
  "description": "Matrice enquête visuelle Paramètres KDE Plasma — v15 full front (linux-kde-neon).",
  "registry": "linux-kde-neon",
  "phiThreshold": 90,
  "uiComponentsContract": "etc/capsuleos/contracts/ui-components-kde.json",
  "parityMatrix": "root/tools/lab/kde-settings-parity-matrix.json",
  "controlsRegistry": "root/tools/lab/kde-settings-controls-registry.json",
  "geometryDefaults": { "width": 1060, "height": 808, "geometryAligned": true },
  "investigations": [
    {
      "controlId": "kcm-display-config",
      "capsulePanel": "display-config",
      "label": "KCM Affichage & Écran (kcm_kscreen)",
      "template": "systemsettings_kde_neon.html",
      "surfaces": ["settings-app", "kcm-sidebar", "kscreen-monitors"],
      "vmLaunch": "systemsettings kcm_kscreen",
      "parityPriority": "P0",
      "geometry": { "width": 1060, "height": 808 }
    },
    {
      "controlId": "hub-sidebar",
      "capsulePanel": "hub",
      "label": "Hub System Settings (sidebar catégories)",
      "template": "systemsettings_kde_neon.html",
      "surfaces": ["settings-app", "sidebar-panels", "search-field"],
      "vmLaunch": "gtk-launch systemsettings.desktop",
      "parityPriority": "P0",
      "geometry": { "width": 1060, "height": 808 }
    },
    {
      "controlId": "appearance-panel",
      "capsulePanel": "appearance",
      "label": "KCM Thème global (kcm_lookandfeel)",
      "template": "systemsettings_kde_neon.html",
      "surfaces": ["settings-app", "theme-choices"],
      "vmLaunch": "systemsettings kcm_lookandfeel",
