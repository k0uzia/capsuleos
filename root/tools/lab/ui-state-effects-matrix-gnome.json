{
  "version": 1,
  "description": "Matrice GNOME — états, transitions, effets, menus (ground truth VM).",
  "surfaces": [
    {
      "id": "desktop.background",
      "label": "Bureau",
      "states": ["idle", "context-menu-open"]
    },
    {
      "id": "shell.overview",
      "label": "Aperçu GNOME",
      "states": ["hidden", "workspace", "apps"]
    },
    {
      "id": "shell.quickSettings",
      "label": "Réglages rapides",
      "states": ["closed", "open"]
    },
    {
      "id": "shell.topBar",
      "label": "Barre supérieure",
      "states": ["idle", "calendar-open", "system-menu-open"]
    },
    {
      "id": "app.nautilus",
      "label": "Fichiers (Nautilus)",
      "states": ["closed", "open", "item-selected", "context-menu-open", "rename-inline"]
    },
    {
      "id": "app.window",
      "label": "Fenêtre CSD",
      "states": ["normal", "focused", "maximized", "closing"]
    }
  ],
  "transitions": [
    {
      "id": "desktop.contextmenu",
      "surface": "desktop.background",
      "from": "idle",
      "to": "context-menu-open",
      "playbookVm": "desktop-contextmenu",
      "trigger": { "type": "contextmenu", "button": "right", "clicks": 1 },
      "effects": {
        "properties": ["opacity", "box-shadow", "backdrop-filter", "border-radius"],
        "durationMs": 150,
        "easing": "ease-out"
      },
      "menus": [
        {
          "role": "context-menu",
          "id": "desktop-context",
          "items": ["New Folder", "Paste", "Display Settings", "Change Background…"]
        }
      ],
      "burstMs": [0, 80, 150, 300],
      "parity": "P0"
    },
    {
      "id": "shell.overview.open",
      "surface": "shell.overview",
      "from": "hidden",
      "to": "workspace",
      "playbookVm": "overview-open",
      "trigger": { "type": "keyboard", "binding": "Super" },
      "effects": {
        "properties": ["opacity", "transform", "filter", "backdrop-filter"],
        "durationMs": 250,
        "easing": "ease-out"
      },
      "burstMs": [0, 120, 250, 500],
      "parity": "P0"
    },
    {
      "id": "shell.overview.close",
      "surface": "shell.overview",
      "from": "workspace",
      "to": "hidden",
      "playbookVm": "overview-close",
      "trigger": { "type": "keyboard", "binding": "Escape" },
      "effects": {
        "properties": ["opacity", "transform"],
        "durationMs": 200,
        "easing": "ease-in"
      },
      "burstMs": [0, 100, 200],
      "parity": "P0"
    },
    {
      "id": "shell.quickSettings.open",
      "surface": "shell.quickSettings",
      "from": "closed",
      "to": "open",
      "playbookVm": "quick-settings",
      "trigger": { "type": "keyboard", "binding": "<Super>s" },
      "effects": {
        "properties": ["opacity", "transform", "box-shadow", "backdrop-filter"],
        "durationMs": 200,
        "easing": "ease-out"
      },
      "menus": [
        {
          "role": "popover",
          "id": "quick-settings",
          "items": ["Volume", "Network", "Night Light", "Power"]
        }
      ],
      "burstMs": [0, 50, 150, 300],
      "parity": "P0"
    },
    {
      "id": "app.nautilus.open",
      "surface": "app.nautilus",
      "from": "closed",
      "to": "open",
      "playbookVm": "open-nautilus",
      "trigger": { "type": "launcher", "clicks": 2 },
      "effects": {
        "properties": ["opacity", "transform", "box-shadow"],
        "durationMs": 200,
        "easing": "ease-out"
      },
      "burstMs": [0, 100, 400, 1400],
      "parity": "P0"
    },
    {
      "id": "app.nautilus.contextmenu",
      "surface": "app.nautilus",
      "from": "open",
      "to": "context-menu-open",
      "playbookVm": "nautilus-contextmenu",
      "trigger": { "type": "contextmenu", "button": "right", "clicks": 1 },
      "effects": {
        "properties": ["opacity", "box-shadow", "backdrop-filter"],
        "durationMs": 120,
        "easing": "ease-out"
      },
      "menus": [
        {
          "role": "context-menu",
          "id": "nautilus-file",
          "items": ["Open", "Open With", "Cut", "Copy", "Rename…", "Move to Trash", "Properties"]
        }
      ],
      "burstMs": [0, 80, 150, 400],
      "parity": "P0"
    },
    {
      "id": "app.nautilus.rename-inline",
      "surface": "app.nautilus",
      "from": "item-selected",
      "to": "rename-inline",
      "playbookVm": "nautilus-item-rename-inline",
      "trigger": { "type": "keyboard", "binding": "F2" },
      "effects": {
        "properties": ["background", "border-radius", "box-shadow"],
        "durationMs": 100,
        "easing": "linear"
      },
      "burstMs": [0, 100, 300],
      "parity": "P0"
    },
    {
      "id": "shell.workspaces.next",
      "surface": "shell.overview",
      "from": "workspace",
      "to": "workspace",
      "playbookVm": "workspace-next",
      "trigger": { "type": "keyboard", "binding": "<Super>Page_Down" },
      "effects": {
        "properties": ["transform", "opacity"],
        "durationMs": 300,
        "easing": "ease-in-out"
      },
      "burstMs": [0, 150, 300],
      "parity": "P1"
    },
    {
      "id": "shell.overview.animation-burst",
      "surface": "shell.overview",
      "from": "hidden",
      "to": "workspace",
      "playbookVm": "animation-overview-burst",
      "trigger": { "type": "keyboard", "binding": "Super" },
      "effects": {
        "properties": ["opacity", "transform", "filter"],
        "durationMs": 250,
        "easing": "ease-out"
      },
      "burstMs": [0, 40, 80, 120, 160, 200, 280],
      "parity": "P0"
    }
  ]
}
